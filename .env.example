# ─── Demo（仅交互式演示用，非生产配置） ─────────────────────

# Demo 使用的模型供应商: anthropic | openai
# DEMO_PROVIDER=anthropic

# Demo 使用的模型名称
# DEMO_MODEL=claude-sonnet-4-6

# Demo 兼容供应商地址（可选，填后走兼容接口）
# DEMO_BASE_URL=

# ─── 模型 API Key（至少配置一个） ───────────────────────────

# Anthropic（Claude 系列模型）
ANTHROPIC_API_KEY=

# OpenAI（GPT 系列模型）
OPENAI_API_KEY=

# ─── 兼容供应商（使用 base_url 指向兼容接口） ─────────────────
# 在 config/seed/models.yaml 中配置 provider: openai + base_url 即可接入
# API Key 通过环境变量提供，或直接写在 models.yaml 的 api_key 字段

# DeepSeek（OpenAI 兼容）
# DEEPSEEK_API_KEY=

# Moonshot / Kimi（OpenAI 兼容）
# MOONSHOT_API_KEY=

# 智谱 GLM（OpenAI 兼容）
# ZHIPU_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=

# 本地模型（vLLM / Ollama / LocalAI 等，无需 key）
# base_url 配在 models.yaml 中，api_key 设为任意值即可

# ─── 日志 ──────────────────────────────────────────────────

# 日志输出目录（默认 logs）
LOG_DIR=logs

# 日志级别：DEBUG / INFO / WARNING / ERROR（默认 INFO）
LOG_LEVEL=INFO

# ─── LangSmith（仅开发环境，生产禁用） ─────────────────────

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ─── OpenTelemetry（可选，生产可观测性） ───────────────────

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── 数据库（P0 不需要，后续生产环境使用） ─────────────────

# PostgreSQL（Checkpointer + Store + DocumentStore）
# DATABASE_URI=postgresql://user:password@localhost:5432/artipivot

# Redis（限流 + 本地缓存 + 分布式锁）
# REDIS_URI=redis://localhost:6379/0

# ─── 存储后端（P0 默认 memory，零外部依赖） ────────────────

# DocumentStore 后端：memory | mongodb | postgres | redis
# STORAGE_DOCUMENT_BACKEND=memory

# ChangeNotifier 后端：memory | mongodb_stream | redis_pubsub | postgres_listen
# STORAGE_NOTIFIER_BACKEND=memory

# ArtifactStore 后端：memory | local | s3 | gcs
# STORAGE_ARTIFACT_BACKEND=memory
