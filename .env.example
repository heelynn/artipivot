# ─── Demo（仅交互式演示用，非生产配置） ─────────────────────

# Demo 使用的模型供应商: anthropic | openai
# DEMO_PROVIDER=anthropic

# Demo 使用的模型名称
# DEMO_MODEL=claude-sonnet-4-6

# Demo 兼容供应商地址（可选，填后走兼容接口）
# DEMO_BASE_URL=

# ─── CLI 一键启动（artipivot serve） ─────────────────────────

# Agent Manifest 文件路径。启动时直接读取，定义所有 Agent、Tool、路由、Prompt。
# 可以是文件路径或目录（目录内找 agents.yaml）。
# 默认: .agents.yaml（项目根目录）
# 参考示例: config/seed/agents.yaml
ARTIPIVOT_AGENTS_MANIFEST=.agents.yaml

# 启动命令：artipivot serve [--manifest .agents.yaml] [--log-level INFO]

# ─── 模型 API Key（至少配置一个） ───────────────────────────

# Anthropic（Claude 系列模型）
ANTHROPIC_API_KEY=

# OpenAI（GPT 系列模型）
OPENAI_API_KEY=

# ─── 兼容供应商（使用 base_url 指向兼容接口） ─────────────────
# 在 config/seed/models.yaml 中配置 provider: openai + base_url 即可接入
# API Key 通过环境变量提供，或直接写在 models.yaml 的 api_key 字段

# DeepSeek（OpenAI 兼容）
# DEEPSEEK_API_KEY=

# Moonshot / Kimi（OpenAI 兼容）
# MOONSHOT_API_KEY=

# 智谱 GLM（OpenAI 兼容）
# ZHIPU_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=

# 本地模型（vLLM / Ollama / LocalAI 等，无需 key）
# base_url 配在 models.yaml 中，api_key 设为任意值即可

# ─── 日志 ──────────────────────────────────────────────────

# 日志输出目录（默认 logs）
ARTIPIVOT_LOG_DIR=logs

# 日志级别：DEBUG / INFO / WARNING / ERROR（默认 INFO）
ARTIPIVOT_LOG_LEVEL=INFO

# 日志格式：json | text（默认 json）
ARTIPIVOT_LOG_FORMAT=json

# 日志输出目标：file | console | both（默认 file）
ARTIPIVOT_LOG_OUTPUT=file

# 日志时区：IANA 时区名（默认 Asia/Shanghai）
ARTIPIVOT_LOG_TZ=Asia/Shanghai

# ─── LangSmith（仅开发环境，生产禁用） ─────────────────────

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ─── OpenTelemetry（可选，生产可观测性） ───────────────────

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── 数据库（P0 不需要，后续生产环境使用） ─────────────────

# PostgreSQL（Checkpointer + Store + DocumentStore）
# DATABASE_URI=postgresql://user:password@localhost:5432/artipivot

# Redis（限流 + 本地缓存 + 分布式锁）
# REDIS_URI=redis://localhost:6379/0

# ─── 存储后端（一行切换） ───────────────────────────────────

# 存储模式: memory（默认，SQLite 本地持久化）| persistent（外部数据库）
# memory:     零配置，数据存 .artipivot/data.db（SQLite），进程重启不丢
# persistent: 需要 register_persistent(YourFactory()) 注册外部存储
ARTIPIVOT_STORAGE_MODE=memory

# 外部数据库 URI（mode=persistent 时需要）
# DATABASE_URI=postgresql://user:password@localhost:5432/artipivot
# DATABASE_URI=mongodb://localhost:27017/artipivot

# 通知轮询间隔（秒），默认 1.0
# PollingChangeNotifier 通过轮询 notifications 表实现变更通知
# ARTIPIVOT_NOTIFY_POLL_INTERVAL=1.0
